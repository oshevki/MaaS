{
  "name": "maas-mvp",
  "version": "0.2.0",
  "description": "Memory as a Service - Event-Driven AI Mentor with Long-term Semantic Memory",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node server.ts",
    "start": "node dist/server.js",
    "orchestrator": "ts-node main.ts",
    "test-runner": "ts-node learning-agent/emulator/src/cli.ts",
    "db:migrate": "ts-node db/run-migrations.ts",
    "db:schema": "ts-node db/run-migrations.ts schema",
    "db:seeds": "ts-node db/run-migrations.ts seeds",
    "db:test": "ts-node shared/test-connection.ts",
    "db:local:up": "docker compose up -d postgres",
    "db:local:down": "docker compose down"
  },
  "keywords": [
    "ai",
    "memory",
    "llm",
    "event-driven"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "openai": "^4.20.1",
    "pg": "^8.11.3",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.5",
    "@types/pg": "^8.10.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
